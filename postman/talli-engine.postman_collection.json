{
  "info": {
    "name": "Talli Engine",
    "description": "API collection for the Talli engine service. Self-contained: baseUrl/email/tokens live as collection variables, so it works with NO environment selected. Verify OTP and Refresh auto-capture tokens into collection variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:7291/api" },
    { "key": "email", "value": "alumonabenaiah71@gmail.com" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "workspaceId", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "linkCode", "value": "" },
    { "key": "deepLink", "value": "" },
    { "key": "linkedChatId", "value": "" },
    { "key": "pickerToken", "value": "" },
    { "key": "pickerItemId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Request OTP",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"mode\": \"login\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/request-otp", "host": ["{{baseUrl}}"], "path": ["auth", "request-otp"] }
          }
        },
        {
          "name": "Verify OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "  if (res.data.user) pm.collectionVariables.set('userId', res.data.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"code\": \"000000\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/verify-otp", "host": ["{{baseUrl}}"], "path": ["auth", "verify-otp"] }
          }
        },
        {
          "name": "Refresh token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
          }
        }
      ]
    },
    {
      "name": "Workspaces",
      "item": [
        {
          "name": "List workspaces",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/workspaces", "host": ["{{baseUrl}}"], "path": ["workspaces"] }
          }
        },
        {
          "name": "Create workspace",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Benaiah Football Club\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/workspaces", "host": ["{{baseUrl}}"], "path": ["workspaces"] }
          }
        },
        {
          "name": "Switch active workspace",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/switch",
              "host": ["{{baseUrl}}"],
              "path": ["workspaces", "{{workspaceId}}", "switch"]
            }
          }
        }
      ]
    },
    {
      "name": "Chat",
      "description": "Chat linking — issue a one-time code, then redeem it from the bot via t.me/<bot>?start=<code> (DM) or /start <code> posted by a group admin (group). Codes are hashed, single-use, expire in 15 min.",
      "item": [
        {
          "name": "Create link code (DM)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) {",
                  "  pm.collectionVariables.set('linkCode', res.data.code);",
                  "  pm.collectionVariables.set('deepLink', res.data.deepLink);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"platform\": \"telegram\",\n  \"purpose\": \"private_link\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/chat/link-codes", "host": ["{{baseUrl}}"], "path": ["chat", "link-codes"] }
          }
        },
        {
          "name": "Create link code (group)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) {",
                  "  pm.collectionVariables.set('linkCode', res.data.code);",
                  "  pm.collectionVariables.set('deepLink', res.data.deepLink);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"platform\": \"telegram\",\n  \"purpose\": \"group_link\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/chat/link-codes", "host": ["{{baseUrl}}"], "path": ["chat", "link-codes"] }
          }
        },
        {
          "name": "List connected chats",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.length) {",
                  "  pm.collectionVariables.set('linkedChatId', res.data[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "description": "Lists chats connected to the active workspace (Telegram DMs + groups), newest first, with who connected each.",
            "url": { "raw": "{{baseUrl}}/chat/connected", "host": ["{{baseUrl}}"], "path": ["chat", "connected"] }
          }
        },
        {
          "name": "Disconnect chat",
          "request": {
            "method": "DELETE",
            "header": [],
            "description": "Disconnects a connected chat by id (scoped to the active workspace). The chat must run /start <code> again to reconnect.",
            "url": {
              "raw": "{{baseUrl}}/chat/connected/{{linkedChatId}}",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "connected", "{{linkedChatId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Wallet",
      "description": "Internal wallet (v2). Balance is the wallet_transactions ledger sum. Top-up issues a flash account number to transfer into; the polling cron credits the wallet once it lands.",
      "item": [
        {
          "name": "Get wallet balance",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/wallet", "host": ["{{baseUrl}}"], "path": ["wallet"] }
          }
        },
        {
          "name": "Wallet history",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/wallet/history", "host": ["{{baseUrl}}"], "path": ["wallet", "history"] }
          }
        },
        {
          "name": "Start top-up",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) {",
                  "  pm.collectionVariables.set('orderReference', res.data.orderReference);",
                  "  pm.collectionVariables.set('flashAccountNumber', res.data.flashAccountNumber);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "description": "Hits LIVE Nomba — returns a real flash account number. Transfer to it from a bank app; the cron credits the wallet.",
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 1000\n}" },
            "url": { "raw": "{{baseUrl}}/wallet/topup", "host": ["{{baseUrl}}"], "path": ["wallet", "topup"] }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List users",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] }
          }
        },
        {
          "name": "Get user by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Person Picker",
      "item": [
        {
          "name": "Get picker by token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.items && res.data.items[0]) {",
                  "  pm.collectionVariables.set('pickerItemId', res.data.items[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/person-pickers/by-token/{{pickerToken}}",
              "host": ["{{baseUrl}}"],
              "path": ["person-pickers", "by-token", "{{pickerToken}}"]
            }
          }
        },
        {
          "name": "Checkout selection",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payerName\": \"Tolu\",\n  \"selections\": [\n    { \"itemId\": \"{{pickerItemId}}\", \"quantity\": 2 }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/person-pickers/by-token/{{pickerToken}}/checkout",
              "host": ["{{baseUrl}}"],
              "path": ["person-pickers", "by-token", "{{pickerToken}}", "checkout"]
            }
          }
        },
        {
          "name": "List pickers (auth)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/person-pickers",
              "host": ["{{baseUrl}}"],
              "path": ["person-pickers"]
            }
          }
        }
      ]
    }
  ]
}
