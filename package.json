{
  "name": "talli",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Talli — AI treasurer and savings assistant for chats (Nomba hackathon). Bun + Turbo + Hono + Vite + Prisma.",
  "packageManager": "bun@1.2.19",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --concurrency=20",
    "dev:engine": "turbo run dev --filter=@app/engine",
    "dev:web": "turbo run dev --filter=@app/web",
    "dev:web:no-proxy": "turbo run dev:no-proxy --filter=@app/web",
    "dev:marketing": "turbo run dev --filter=@app/marketing",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean",
    "db:generate": "bun --filter @app/engine db:generate",
    "db:push": "bun --filter @app/engine db:push",
    "db:migrate": "bun --filter @app/engine db:migrate",
    "db:studio": "bun --filter @app/engine db:studio",
    "skills:install": "bash scripts/install-skills.sh",
    "tunnel:push": "bash scripts/tunnel-push.sh"
  },
  "devDependencies": {
    "portless": "^0.14.0",
    "prettier": "^3.4.2",
    "turbo": "^2.5.0",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "date-fns": "^4.4.0",
    "grammy": "^1.44.0"
  }
}
