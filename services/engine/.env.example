NODE_ENV=development
PORT=7291

DATABASE_URL=postgres://postgres:12345@localhost:5433/talli_dev

REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=2592000
COOKIE_DOMAIN=
WEB_APP_URL=https://talli.localhost
CLIENT_URL=https://talli.localhost
PUBLIC_API_URL=

MAIL_FROM=noreply@talli.app

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

OPENROUTER_API_KEY=

TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_ID=

FEATURE_FLAGS=

# ── Nomba ──────────────────────────────────────────────
# Active environment: test → sandbox.nomba.com, live → api.nomba.com
NOMBA_ENV=test

# Shared across both envs (same business/account)
NOMBA_PARENT_ACCOUNT_ID=
NOMBA_SUB_ACCOUNT_ID=
NOMBA_WEBHOOK_SECRET=

# TEST creds — only valid against the sandbox (lookups return mock data)
NOMBA_TEST_CLIENT_ID=
NOMBA_TEST_PRIVATE_KEY=

# LIVE creds — only valid against production (real NIBSS lookups, real money)
NOMBA_LIVE_CLIENT_ID=
NOMBA_LIVE_PRIVATE_KEY=
# ───────────────────────────────────────────────────────

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_INFO_BANNER_URL=

CHAT_LINK_CODE_TTL_MINUTES=15
