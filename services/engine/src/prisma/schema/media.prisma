enum MediaStatus {
  pending
  ready
  failed
}

model Media {
  id        String      @id @default(cuid())
  userId    String?
  bucketKey String      @unique
  publicUrl String?
  mimeType  String
  size      Int
  status    MediaStatus @default(ready)
  metadata  Json?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId])
  @@map("media")
}
