enum TransferStatus {
  pending
  sent
  failed
}

/// One outbound bank payout. The source of truth for transfer history and
/// receipts, and the row the reconcile cron polls to a final state. `payout()`
/// debits the wallet and creates this as `pending`; only a synchronous Nomba
/// SUCCESS marks it `sent` on the spot — otherwise the cron requeries until
/// SUCCESS (sent) or REFUND (failed, wallet credited back).
model Transfer {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  merchantTxRef String  @unique /// idempotency key — stable across retries, never regenerated while pending
  nombaTxId     String? /// Nomba data.id, used to requery the outcome
  walletRef     String  @unique /// references the wallet/source debit entry; basis for the refund ref
  /// When set, this payout was funded from a collection's balance (not the wallet),
  /// so a failed/refunded transfer restores the collection, not the wallet ledger.
  sourceCollectionId String?

  amount                  Int
  accountNumber           String
  accountName             String
  bankCode                String
  bankName                String?
  narration               String?
  senderName              String?
  createdByPlatformUserId String?

  status        TransferStatus @default(pending)
  failureReason String?
  pollAttempts  Int            @default(0)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([userId])
  @@index([status])
  @@map("transfers")
}
