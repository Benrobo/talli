enum UserRole {
  user
  admin
  super_admin
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String?
  phone      String?
  avatarUrl  String?
  role       UserRole @default(user)
  isVerified Boolean  @default(false)

  passwordHash String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activeWorkspaceId String?

  accounts              Account[]
  sessions              AuthSession[]
  refreshTokens         RefreshToken[]
  ownedWorkspaces       Workspace[]        @relation("WorkspaceOwner")
  workspaceMemberships  WorkspaceMember[]
  verifiedLinkedChats   LinkedChat[]       @relation("LinkedChatVerifier")
  platformIdentities    PlatformUser[]     @relation("PlatformUserAccount")
  chatLinkCodesCreated  ChatLinkCode[]
  collectionsCreated    Collection[]
  personPickersCreated  PersonPicker[]
  collectionMemberships CollectionMember[]
  savingsJars           SavingsJar[]
  paymentsAsPayer       Payment[]          @relation("PaymentPayer")
  wallet                Wallet?
  auditLogs             AuditLog[]

  @@map("users")
}

enum AccountProvider {
  google
  github
  apple
  email
}

model Account {
  id           String          @id @default(cuid())
  provider     AccountProvider
  providerId   String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerId])
  @@index([userId])
  @@map("accounts")
}

model AuthSession {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  userAgent String?
  ipAddress String?
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([sessionId])
  @@map("refresh_tokens")
}
