enum UserRole {
  user
  admin
  super_admin
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String?
  phone      String?
  avatarUrl  String?
  role       UserRole @default(user)
  isVerified Boolean  @default(false)

  passwordHash String?

  walletBalance Int    @default(0)
  currency      String @default("NGN")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts              Account[]
  sessions              AuthSession[]
  refreshTokens         RefreshToken[]
  verifiedLinkedChats   LinkedChat[]       @relation("LinkedChatVerifier")
  platformIdentities    PlatformUser[]     @relation("PlatformUserAccount")
  linkedChats           LinkedChat[]       @relation("LinkedChatOwner")
  chatLinkCodesCreated  ChatLinkCode[]
  botCommands           BotCommand[]
  collections           Collection[]
  billSplitsCreated     BillSplit[]
  collectionMemberships CollectionMember[]
  savingsJars           SavingsJar[]
  beneficiaries         Beneficiary[]
  transfers             Transfer[]
  payments              Payment[]          @relation("PaymentOwner")
  paymentsAsPayer       Payment[]          @relation("PaymentPayer")
  virtualAccount        VirtualAccount?
  auditLogs             AuditLog[]

  @@map("users")
}

model VirtualAccount {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountRef    String   @unique
  accountNumber String
  bankName      String
  accountName   String
  provider      String   @default("nomba")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("virtual_accounts")
}

enum AccountProvider {
  google
  github
  apple
  email
}

model Account {
  id           String          @id @default(cuid())
  provider     AccountProvider
  providerId   String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerId])
  @@index([userId])
  @@map("accounts")
}

model AuthSession {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  userAgent String?
  ipAddress String?
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([sessionId])
  @@map("refresh_tokens")
}
