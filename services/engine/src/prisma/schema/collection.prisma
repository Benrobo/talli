enum CollectionType {
  fixed_per_person
  open_contribution
  named_members
}

enum CollectionStatus {
  draft
  active
  paid
  partially_paid
  expired
  cancelled
  closed
}

enum CollectionMemberStatus {
  not_paid
  pending
  paid
  underpaid
  overpaid
  refunded
  manual_review
}

/// A pool of money gathered from a group — dues, a split bill, a contribution.
/// Created from chat ("collect 5k from everyone") and tied to the `linkedChat` it
/// runs in. Pay-to-enroll: people become members when they tap Pay, so completion
/// is judged against `targetAmount`, not a fixed roster. `amountPerMember` is the
/// per-head amount for `fixed_per_person`.
model Collection {
  id              String           @id @default(cuid())
  workspaceId     String
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  linkedChatId    String?
  linkedChat      LinkedChat?      @relation(fields: [linkedChatId], references: [id], onDelete: SetNull)
  title           String
  purpose         String
  collectionType  CollectionType
  amountPerMember Int?
  targetAmount    Int?
  currency        String           @default("NGN")
  deadline        DateTime?
  status          CollectionStatus @default(draft)
  createdByUserId String
  createdBy       User             @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  CollectionMember[]
  payments Payment[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([status])
  @@index([linkedChatId])
  @@map("collections")
}

/// One participant in a collection, created on their first Pay tap (pay-to-enroll).
/// `expectedAmount` is what they owe; `paidAmount` accrues as their transfers land.
/// The link a payment reconciles back to — crediting bumps `paidAmount` + `status`.
model CollectionMember {
  id             String                 @id @default(cuid())
  collectionId   String
  collection     Collection             @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  displayName    String
  platformUserId String?
  appUserId      String?
  appUser        User?                  @relation(fields: [appUserId], references: [id], onDelete: SetNull)
  expectedAmount Int
  paidAmount     Int                    @default(0)
  status         CollectionMemberStatus @default(not_paid)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments Payment[]

  @@index([collectionId])
  @@index([collectionId, platformUserId])
  @@index([appUserId])
  @@map("collection_members")
}
