enum SavingsJarStatus {
  active
  locked
  completed
  cancelled
  withdrawn
}

model SavingsJar {
  id            String           @id @default(cuid())
  ownerUserId   String
  owner         User             @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  name          String
  icon          String           @default("piggy")
  accentColor   String           @default("#6d4ae6")
  targetAmount  Int?
  currentAmount Int              @default(0)
  currency      String           @default("NGN")
  lockUntil     DateTime?
  status        SavingsJarStatus @default(active)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments Payment[]

  @@index([ownerUserId])
  @@index([status])
  @@map("savings_jars")
}
