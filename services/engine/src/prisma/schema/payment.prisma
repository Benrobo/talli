enum PaymentProvider {
  nomba
}

enum PendingPaymentStatus {
  pending
  completed
  expired
  failed
}

enum PendingPaymentPurpose {
  topup
  collection
}

enum PaymentStatus {
  pending
  successful
  failed
  cancelled
}

model Payment {
  id                 String            @id @default(cuid())
  workspaceId        String
  workspace          Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  collectionId       String?
  collection         Collection?       @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  collectionMemberId String?
  collectionMember   CollectionMember? @relation(fields: [collectionMemberId], references: [id], onDelete: SetNull)
  savingsJarId       String?
  savingsJar         SavingsJar?       @relation(fields: [savingsJarId], references: [id], onDelete: SetNull)
  payerUserId        String?
  payer              User?             @relation("PaymentPayer", fields: [payerUserId], references: [id], onDelete: SetNull)
  payerPlatformId    String?
  amount             Int
  currency           String            @default("NGN")
  provider           PaymentProvider   @default(nomba)
  providerReference  String?
  providerOrderId    String?
  status             PaymentStatus     @default(pending)
  paidAt             DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  savingsTransactions SavingsTransaction[]

  @@index([workspaceId])
  @@index([collectionId])
  @@index([savingsJarId])
  @@index([providerReference])
  @@index([providerOrderId])
  @@index([status])
  @@map("payments")
}

/// A queued inbound bank transfer reconciled by polling (not webhooks). Serves
/// wallet top-ups (walletId) and collection payments (collectionMemberId). The
/// flash account number is what the payer transfers to.
model PendingPayment {
  id                  String                @id @default(cuid())
  orderRefId          String                @unique
  purpose             PendingPaymentPurpose
  walletId            String?
  collectionId        String?
  collectionMemberId  String?
  payerPlatformUserId String?
  amount              Int
  flashAccountNumber  String?
  flashBankName       String?
  flashAccountName    String?
  status              PendingPaymentStatus  @default(pending)
  pollAttempts        Int                   @default(0)
  expiresAt           DateTime?
  completedAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("pending_payments")
}
