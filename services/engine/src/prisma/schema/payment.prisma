enum PaymentProvider {
  nomba
}

enum PaymentDirection {
  credit
  debit
}

enum PaymentKind {
  wallet_topup
  collection_payment
  savings_deposit
  savings_withdrawal
  collection_withdrawal
  transfer_out
  refund
}

enum PaymentStatus {
  pending
  successful
  failed
  cancelled
}

enum PendingPaymentStatus {
  pending
  completed
  expired
  failed
  cancelled
}

enum PendingPaymentPurpose {
  wallet_topup
  savings_funding
  collection
}

model Payment {
  id                 String            @id @default(cuid())
  userId             String
  user               User              @relation("PaymentOwner", fields: [userId], references: [id], onDelete: Cascade)
  direction          PaymentDirection
  kind               PaymentKind
  amount             Int
  currency           String            @default("NGN")
  status             PaymentStatus     @default(successful)
  balanceAfter       Int?
  collectionId       String?
  collection         Collection?       @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  collectionMemberId String?
  collectionMember   CollectionMember? @relation(fields: [collectionMemberId], references: [id], onDelete: SetNull)
  savingsJarId       String?
  savingsJar         SavingsJar?       @relation(fields: [savingsJarId], references: [id], onDelete: SetNull)
  transferId         String?
  payerUserId        String?
  payer              User?             @relation("PaymentPayer", fields: [payerUserId], references: [id], onDelete: SetNull)
  payerPlatformId    String?
  provider           PaymentProvider   @default(nomba)
  providerReference  String?
  providerOrderId    String?
  referenceId        String?           @unique
  paidAt             DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, kind])
  @@index([collectionId])
  @@index([savingsJarId])
  @@index([providerReference])
  @@index([providerOrderId])
  @@index([status])
  @@map("payments")
}

model PendingPayment {
  id                   String                @id @default(cuid())
  orderRefId           String                @unique
  purpose              PendingPaymentPurpose
  userId               String?
  savingsJarId         String?
  collectionId         String?
  collectionMemberId   String?
  payerPlatformUserId  String?
  amount               Int
  virtualAccountNumber String?
  flashAccountNumber   String?
  flashBankName        String?
  flashAccountName     String?
  status               PendingPaymentStatus  @default(pending)
  providerTransactionId String?              @unique
  pollAttempts         Int                   @default(0)
  expiresAt            DateTime?
  completedAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([userId])
  @@map("pending_payments")
}
