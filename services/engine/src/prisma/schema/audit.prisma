model AuditLog {
  id              String  @id @default(cuid())
  actorUserId     String?
  actor           User?   @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  actorPlatformId String?
  action          String
  entityType      String
  entityId        String
  metadata        Json?

  createdAt DateTime @default(now())

  @@index([actorUserId])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
